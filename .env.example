# LLM Configuration (Required)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama2

# Embedding Configuration (Optional - defaults provided)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking Configuration (Optional - defaults provided)
PARENT_CHUNK_SIZE=2048
CHILD_CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration (Optional - defaults provided)
VECTOR_TOP_K=10
BM25_TOP_K=10
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.7

# Graph Configuration (Optional - defaults provided)
MAX_GRAPH_DEPTH=3
ENTITY_SIMILARITY_THRESHOLD=0.85

# Context Configuration (Optional - defaults provided)
MAX_CONTEXT_TOKENS=4096
FAITHFULNESS_THRESHOLD=0.8

# Storage Configuration (Optional - defaults provided)
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/graph_rag

# Logging Configuration (Optional)
LOG_LEVEL=INFO
LOG_FILE=
STRUCTURED_LOGGING=true
